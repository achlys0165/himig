{
  "buildCommand": "vite build",
  "framework": "vite",
  "installCommand": "npm install",
  "functions": {
    "api/send-email.ts": {
      "runtime": "@vercel/node@3"
    },
    "api/email-action.ts": {
      "runtime": "@vercel/node@3"
    }
  },
  "rewrites": [
    {
      "source": "/api/send-email",
      "destination": "/api/send-email.ts"
    },
    {
      "source": "/api/email-action",
      "destination": "/api/email-action.ts"
    },
    {
      "source": "/((?!api/.*).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
