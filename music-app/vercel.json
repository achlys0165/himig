{
  "buildCommand": "vite build",
  "framework": "vite",
  "installCommand": "npm install",
  "routes": [
    {
      "src": "/api/send-email",
      "dest": "/api/send-email.ts"
    },
    {
      "src": "/api/email-action",
      "dest": "/api/email-action.ts"
    },
    {
      "src": "/((?!api/).*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}